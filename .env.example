# ==========================================
# GCP 智能財報分析助手 - 環境變數設定範本
# 請複製此檔案並重新命名為 .env，然後填入您的金鑰與設定。
# ==========================================

# 1. 模型供應商與對話模型設定 (支援: google_gemini, openai, anthropic, vertex_ai, ollama, mock)
MODEL_TYPE=google_gemini

# 2. 各平台 API 金鑰設定
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 3. GCP Vertex AI 配置 (若 MODEL_TYPE=vertex_ai 時使用)
# 請確保已在環境中運行 gcloud auth application-default login 或設定環境變數 GOOGLE_APPLICATION_CREDENTIALS
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_REGION=us-central1

# 4. GCP AlloyDB / PostgreSQL 資料庫連線設定 (若無設定，本地端會自動採用 SQLite 記憶體資料庫)
DATABASE_URL=postgresql+psycopg2://user:password@host:port/dbname

# 5. LINE Bot 對接設定
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# 6. 系統日誌等級 (INFO / DEBUG / WARNING)
LOG_LEVEL=INFO
